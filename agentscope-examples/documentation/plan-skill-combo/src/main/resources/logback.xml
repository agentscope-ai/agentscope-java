<configuration scan="false">

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%logger{0}] %msg%n</pattern>
            <charset>utf-8</charset>
        </encoder>
    </appender>

    <!-- AgentTraceHook: INFO=工具调用摘要, DEBUG=详细参数/结果 -->
    <logger name="io.agentscope.harness.agent.hook.AgentTraceHook" level="DEBUG"/>

    <!-- 如需 DEBUG 级别查看工具参数和结果详情，改为 DEBUG
    <logger name="io.agentscope.harness.agent.hook.AgentTraceHook" level="DEBUG"/>
    -->

    <!-- 沉默其他日志 -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
